{
  "name": "payload-exchange",
  "private": true,
  "packageManager": "bun@1.2.21",
  "workspaces": ["apps/*", "packages/*", "tooling/*"],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "test": "bun test --recursive",
    "deploy:test": "fly deploy -c fly.testnet.toml",
    "deploy:main": "fly deploy -c fly.mainnet.toml",
    "publish:all": "turbo build && npm publish --workspace=packages/protocol && npm publish --workspace=packages/buyer-sdk && npm publish --workspace=packages/solver-sdk && npm publish --workspace=apps/buyer-agent && npm publish --workspace=apps/solver-agent"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  }
}
